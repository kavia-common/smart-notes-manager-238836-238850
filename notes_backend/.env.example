# Backend configuration (copy to .env and fill values)

# Database (from notes_database container)
POSTGRES_URL=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=

# Auth
# Generate a long random string (at least 32 chars). Keep it secret.
JWT_SECRET_KEY=
# e.g. "HS256"
JWT_ALGORITHM=HS256
# Access token expiry in minutes (e.g. 60)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS (comma-separated list). Use "*" for local/dev only.
CORS_ALLOW_ORIGINS=*
